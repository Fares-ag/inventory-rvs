rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images - allow authenticated users to read and write
    match /product_images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Allow all authenticated access for other paths (you can restrict this later)
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}

